generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户角色枚举
enum UserRole {
  USER          // 普通用户
  VIP           // VIP用户
  ADMIN         // 管理员
  SUPER_ADMIN   // 超级管理员
}

model Admin {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  username    String?
  firstName   String?
  lastName    String?
  createdAt   DateTime @default(now())
  createdBy   String   // Telegram ID of the super admin who added this admin
  isActive    Boolean  @default(true)
}

model User {
  id                String    @id @default(cuid())
  telegramId        String    @unique
  username          String?
  firstName         String?
  lastName          String?
  role              UserRole  @default(USER)
  
  // 付费状态
  isPaid            Boolean   @default(false)
  paidExpireAt      DateTime?
  
  // VIP状态（用于VIP角色）
  isVip             Boolean   @default(false)
  vipExpireAt       DateTime?
  
  // 管理员状态（用于管理员角色）
  isAdmin           Boolean   @default(false)
  adminExpireAt     DateTime?
  
  // 限制
  canCreateLottery  Boolean   @default(false)
  canJoinLottery    Boolean   @default(false)
  dailyJoinCount    Int       @default(0)
  dailyJoinResetAt  DateTime?
  
  // 活跃时间
  lastActiveAt      DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // 关联
  scheduledMessages ScheduledMessage[]
  paymentAddresses  PaymentAddress[]
  winners           Winner[]
}

// 已加入的群/频道 (系统级别，不绑定用户)
model JoinedGroup {
  id          String   @id @default(cuid())
  chatId      String   @unique
  title       String
  type        String   // group / supergroup / channel
  username    String?
  memberCount Int      @default(0)
  inviteLink  String?
  status      String   @default("active") // active / left / kicked
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 强制加入群/频道 (系统级别，不绑定用户)
model ForcedJoinChannel {
  id          String   @id @default(cuid())
  chatId      String   @unique
  title       String
  type        String   // group / supergroup / channel
  username    String?
  inviteLink  String?
  isRequired  Boolean  @default(true)  // 是否必须加入
  isEnabled   Boolean  @default(true)  // 是否启用
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 定时发送消息
model ScheduledMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  content     String
  mediaType   String   @default("none") // none, image, video
  mediaUrl    String?
  targetType  String   // private, group, channel
  targetChatId String?
  scheduledAt DateTime
  repeatType  String   @default("once") // once, daily, weekly, monthly
  status      String   @default("pending") // pending, sent, failed, cancelled
  sentAt      DateTime?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 收款地址
model PaymentAddress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // 地址名称，如"USDT-TRC20"
  currency    String   @default("USDT") // 货币类型：USDT, BTC, ETH等
  network     String   // 网络类型：TRC20, ERC20, BEP20等
  address     String   // 收款地址
  qrCodeUrl   String?  // 二维码图片URL
  isDefault   Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 续费规则
model RenewalRule {
  id          String   @id @default(cuid())
  name        String
  targetRole  String   // user, vip, admin
  days        Int      // -1表示永久
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USDT")
  description String?
  isEnabled   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 收费设置
model BillingSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// 付费订单（统一所有角色的付费）
model PaymentOrder {
  id          String    @id @default(cuid())
  orderNo     String    @unique
  telegramId  String
  orderType   String    // user_renewal, vip_purchase, admin_purchase
  ruleId      String?   // 关联的规则ID
  amount      Decimal   @db.Decimal(10, 2)
  currency    String
  status      String    @default("pending") // pending, paid, cancelled, expired
  expireAt    DateTime? // 订单过期时间
  paidAt      DateTime?
  remark      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 用户购买订单（完整付款流程）
model Order {
  id            String    @id @default(cuid())
  orderNo       String    @unique  // 订单号 ORD + 时间戳
  userId        String    // Telegram ID
  username      String?   // Telegram username
  firstName     String?   // Telegram first name
  ruleId        String    // 关联的续费规则ID
  ruleName      String    // 套餐名称
  amount        String    // 金额
  currency      String    // 货币
  targetRole    String    // user / vip / admin
  days          Int       // 天数，-1表示永久
  paymentProof  String?   // 付款凭证（TxHash 或图片URL）
  status        String    @default("pending")  // pending / confirmed / rejected
  confirmedAt   DateTime?
  confirmedBy   String?   // 确认人的 telegramId
  rejectedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 抽奖活动
model Lottery {
  id              String   @id @default(cuid())
  title           String
  description     String?
  mediaType       String   @default("none") // none, image, video
  mediaUrl        String?
  
  // 参与方式
  participationMethod String @default("private") // private, keyword
  keyword         String?  // 群内关键词
  
  // 参与条件
  requireUsername Boolean  @default(false)
  requireChannels String[] // 向后兼容字段，新数据使用 channels 关联
  
  // 开奖设置
  drawType        String   // "time" | "count"
  drawTime        DateTime? // 定时开奖时间
  drawCount       Int?     // 人满开奖人数
  
  // 状态
  status          String   @default("active") // active, drawn, cancelled
  
  // 通知模板
  winnerNotification  String @default("恭喜 {member}！您中奖了：{goodsName}")
  creatorNotification String @default("抽奖\"{lotteryTitle}\"已开奖，中奖用户已通知。")
  groupNotification   String @default("抽奖结果已公布！中奖名单：{awardUserList}")
  
  // 推送消息模板
  publishTemplate     String @default("🎉 {lotteryTitle}\n\n{lotteryDesc}\n\n🎁 奖品：{goodsList}\n👥 参与条件：{joinCondition}\n⏰ 开奖条件：{openCondition}\n\n当前参与：{joinNum} 人")
  
  // 关联
  createdBy       String   // 创建者 Telegram ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  drawnAt         DateTime?
  
  channels        LotteryChannel[]
  prizes          Prize[]
  participants    Participant[]
  winners         Winner[]
  publishes       LotteryPublish[]
}

// 群/频道信息
model LotteryChannel {
  id          String   @id @default(cuid())
  lotteryId   String
  lottery     Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  chatId      String   // Telegram 群/频道 ID
  title       String   // 群/频道名称
  type        String   // group, supergroup, channel
  username    String?  // @username（如果有）
  inviteLink  String?  // 邀请链接（公开频道为 https://t.me/username，私密频道为 https://t.me/+ABC123）
  createdAt   DateTime @default(now())
  
  @@unique([lotteryId, chatId])
}

// 奖品
model Prize {
  id          String   @id @default(cuid())
  lotteryId   String
  lottery     Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  name        String
  total       Int
  remaining   Int
  createdAt   DateTime @default(now())
  winners     Winner[]
}

// 参与者
model Participant {
  id          String   @id @default(cuid())
  lotteryId   String
  lottery     Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  telegramId  String
  username    String?
  firstName   String?
  lastName    String?
  invitedBy   String?  // 被谁邀请的 Telegram ID
  inviteCount Int      @default(0) // 邀请了多少人
  joinedAt    DateTime @default(now())
  
  @@unique([lotteryId, telegramId])
}

// 中奖者
model Winner {
  id          String    @id @default(cuid())
  lotteryId   String
  lottery     Lottery   @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  telegramId  String
  username    String?
  firstName   String?
  prizeId     String
  prize       Prize     @relation(fields: [prizeId], references: [id], onDelete: Cascade)
  prizeName   String
  notified    Boolean   @default(false)
  claimed     Boolean   @default(false)
  claimedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  wonAt       DateTime  @default(now())
}

// 推送记录
model LotteryPublish {
  id          String   @id @default(cuid())
  lotteryId   String
  lottery     Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  chatId      String   // 推送到的群/频道 ID
  chatTitle   String?  // 群/频道名称
  messageId   String?  // 推送的消息 ID（用于编辑更新）
  publishedAt DateTime @default(now())
  publishedBy String   // 推送者 Telegram ID
  
  @@index([lotteryId, chatId])
}

// 消息模板
model Template {
  id          String   @id @default(cuid())
  type        String   // edit_success, user_join_prompt, user_join_success, winner_private, creator_private, winner_public, publish
  content     String
  buttons     Json?    // 按钮配置 [{text: string, url: string}]
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 公告群/频道
model AnnouncementChannel {
  id        String   @id @default(cuid())
  chatId    String   @unique
  title     String
  type      String   // group, supergroup, channel
  username  String?
  createdAt DateTime @default(now())
  createdBy String   // 超管ID
}

// 私聊命令
model BotCommand {
  id          String   @id @default(cuid())
  command     String   @unique  // /start, /new, /create 等
  prompt      String             // 命令提示，如"开始"
  description String?            // 功能描述
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 系统设置
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// 黑名单
model Blacklist {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  username    String?
  reason      String?
  createdBy   String   // 操作管理员的 Telegram ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 提醒设置
model ReminderSetting {
  id              String   @id @default(cuid())
  isEnabled       Boolean  @default(true)
  reminderDays    String   @default("7,3,1") // 逗号分隔的天数
  vipTemplate     String?  // VIP 过期提醒模板
  adminTemplate   String?  // 管理员过期提醒模板
  userTemplate    String?  // 普通用户过期提醒模板
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 提醒记录（防止重复发送）
model ReminderLog {
  id          String   @id @default(cuid())
  telegramId  String
  type        String   // vip / admin / user
  daysLeft    Int      // 剩余天数
  sentAt      DateTime @default(now())
  
  @@unique([telegramId, type, daysLeft])
}

// ============================================================
// 教师评价平台
// ============================================================

// 快速评价记录（系统A）
model QuickEvaluation {
  id               String   @id @default(cuid())
  teacherUsername  String   // 被评价教师的用户名（不含@）
  raterId          String   // 评价人 Telegram ID
  raterUsername    String?
  raterName        String?
  isPositive       Boolean  // true=👍推荐, false=👎不推荐
  reason           String   // 理由（≥12字）
  groupId          String?  // 来源群组 ID
  createdAt        DateTime @default(now())

  @@index([teacherUsername])
  @@index([raterId])
}

// 待审核的详细报告（系统B）
model PendingReport {
  id               String   @id @default(cuid())
  teacherUsername  String   // 被报告教师的用户名（不含@）
  authorId         String   // 提交人 Telegram ID
  authorUsername   String?
  authorName       String?
  groupId          String?
  formData         Json     // 表单字段数据 {key: value}
  tags             String[] // 标签数组
  status           String   @default("pending") // pending / approved / rejected
  rejectionReason  String?
  reviewedBy       String?  // 审核人 Telegram ID
  reviewedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  screenshots      ReportScreenshot[]

  @@index([teacherUsername])
  @@index([status])
}

// 已发布的详细报告
model PublishedReport {
  id               String   @id @default(cuid())
  teacherUsername  String
  authorId         String
  authorUsername   String?
  authorName       String?
  formData         Json
  tags             String[]
  channelMessageIds Json?   // {channelId: messageId} 推送到各频道的消息ID
  pendingReportId  String?  // 来源待审核报告ID
  createdAt        DateTime @default(now())

  @@index([teacherUsername])
  @@index([tags])
}

// 预约截图（关联待审核报告）
model ReportScreenshot {
  id        String        @id @default(cuid())
  reportId  String
  report    PendingReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fileId    String        // Telegram file_id
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
}

// 标签字段配置
model TagFieldConfig {
  id         String   @id @default(cuid())
  isEnabled  Boolean  @default(true)
  isRequired Boolean  @default(false)
  mode       String   @default("predefined") // predefined / free
  maxTags    Int      @default(5)
  fieldLabel String   @default("标签")
  updatedAt  DateTime @updatedAt
}

// 预定义标签
model PredefinedTag {
  id        String   @id @default(cuid())
  tag       String   @unique
  sortOrder Int      @default(0)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
}

// 评价平台频道配置
model EvalChannel {
  id        String   @id @default(cuid())
  chatId    String   @unique
  title     String
  type      String   @default("report") // report（报告推送频道）/ subscribe（强制订阅频道）
  username  String?
  inviteLink String?
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 报告表单模板
model ReportTemplate {
  id        String   @id @default(cuid())
  fields    Json     // [{key, label, order, required, type}]
  header    String   @default("")
  footer    String   @default("")
  updatedAt DateTime @updatedAt
}

// 用户评价操作状态（FSM）
model UserEvalState {
  id        String   @id @default(cuid())
  userId    String   @unique
  state     String   // quick_reason / report_field_N / report_screenshots / report_tags / report_preview
  data      Json?    // 已收集的数据 {teacherUsername, groupId, fieldIndex, formData, tags, screenshots}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
