# ============================================================
# 教师评价平台 - 环境变量配置
# ============================================================

# ----------------------------------------
# Telegram Bot 配置（必填）
# ----------------------------------------

# Bot Token（从 @BotFather 获取）
BOT_TOKEN=123456789:ABCDEfghijklmnopqrstuvwxyz1234567890

# Bot 用户名（可选）
BOT_USERNAME=your_bot_username

# ----------------------------------------
# 管理员配置（必填）
# ----------------------------------------

# 管理员 ID 列表，用逗号分隔
# 获取方式：给机器人发 /start，查看日志
ADMIN_IDS=123456789,987654321

# ----------------------------------------
# 数据库配置
# ----------------------------------------

# 数据库类型：sqlite / mysql / postgresql
DATABASE_TYPE=sqlite

# SQLite 路径（DATABASE_TYPE=sqlite 时使用）
SQLITE_DB_PATH=data/bot.db

# PostgreSQL 连接 URL（DATABASE_TYPE=postgresql 时使用）
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# MySQL 配置（DATABASE_TYPE=mysql 时使用）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=yhq_db

# ----------------------------------------
# 频道配置（可选）
# ----------------------------------------

# 强制订阅频道 ID，逗号分隔（用户启动时验证）
# REQUIRED_CHANNELS=-1001234567890,-1009876543210

# 报告推送频道 ID，逗号分隔（审核通过后推送）
# REPORT_CHANNELS=-1001234567890

# ----------------------------------------
# 日志配置
# ----------------------------------------

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 日志文件路径（可选，为空则只输出到控制台）
# LOG_FILE=logs/bot.log

# ----------------------------------------
# 应用配置
# ----------------------------------------

# 应用环境：production / development
ENVIRONMENT=production

# 评价理由最小字数
MIN_REASON_LENGTH=12

# 预约截图最小数量
MIN_SCREENSHOTS=1

# 预约截图最大数量
MAX_SCREENSHOTS=3

# 排行榜显示数量
RANKING_LIMIT=10

# 搜索结果最大显示数量
SEARCH_RESULT_LIMIT=10

# ----------------------------------------
# JWT 认证配置
# ----------------------------------------

# JWT 密钥（生产环境必须设置为强随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=your-secret-key-here

# JWT 过期时间（秒，默认 3600 = 1 小时）
# JWT_EXPIRES_IN=3600

# ----------------------------------------
# Redis 缓存配置（可选）
# ----------------------------------------

# Redis 连接 URL（未设置则使用内存缓存）
# REDIS_URL=redis://localhost:6379/0

# 缓存默认 TTL（秒）
# CACHE_DEFAULT_TTL=300

# ----------------------------------------
# 限流配置
# ----------------------------------------

# 用户每分钟最大请求数
# RATE_LIMIT_USER_MAX=10

# 用户限流时间窗口（秒）
# RATE_LIMIT_USER_WINDOW=60

# IP 每分钟最大请求数
# RATE_LIMIT_IP_MAX=100

# ----------------------------------------
# 邮件通知配置（可选）
# ----------------------------------------

# SMTP 服务器地址
# SMTP_HOST=smtp.example.com

# SMTP 端口（587 for TLS, 465 for SSL）
# SMTP_PORT=587

# SMTP 用户名
# SMTP_USER=noreply@example.com

# SMTP 密码
# SMTP_PASSWORD=your_smtp_password

# 发件人邮箱
# SMTP_FROM_EMAIL=noreply@example.com

# 使用 TLS
# SMTP_USE_TLS=true

# ----------------------------------------
# 备份配置
# ----------------------------------------

# 备份目录
# BACKUP_DIR=backups

# 备份间隔（分钟）
# BACKUP_INTERVAL_MINUTES=60

# 备份保留天数
# BACKUP_RETENTION_DAYS=7

# 备份加密密钥（可选）
# BACKUP_ENCRYPTION_KEY=your_fernet_key

# ----------------------------------------
# Elasticsearch 配置（可选）
# ----------------------------------------

# Elasticsearch URL（未设置则使用本地搜索）
# ELASTICSEARCH_URL=http://localhost:9200

# ----------------------------------------
# 加密配置
# ----------------------------------------

# 数据加密密钥（32 字节十六进制，生产必填）
# 生成方式：python -c "import secrets; print(secrets.token_bytes(32).hex())"
# ENCRYPTION_KEY=your_64_char_hex_key

# ----------------------------------------
# 国际化配置
# ----------------------------------------

# 默认语言：zh / en / ja
# DEFAULT_LANGUAGE=zh

# ----------------------------------------
# REST API 配置（可选）
# ----------------------------------------

# 是否启用 REST API
# API_ENABLED=false

# API 监听地址
# API_HOST=0.0.0.0

# API 监听端口
# API_PORT=8080

# API 访问密钥（建议在生产环境设置）
# API_KEY=your_api_key_here
