# ============================================================
# 教师评价平台 - 环境变量配置
# ============================================================

# ----------------------------------------
# Telegram Bot 配置（必填）
# ----------------------------------------

# Bot Token（从 @BotFather 获取）
BOT_TOKEN=123456789:ABCDEfghijklmnopqrstuvwxyz1234567890

# Bot 用户名（可选）
BOT_USERNAME=your_bot_username

# ----------------------------------------
# 管理员配置（必填）
# ----------------------------------------

# 管理员 ID 列表，用逗号分隔
# 获取方式：给机器人发 /start，查看日志
ADMIN_IDS=123456789,987654321

# ----------------------------------------
# 数据库配置
# ----------------------------------------

# 数据库类型：sqlite / mysql / postgresql
DATABASE_TYPE=sqlite

# SQLite 路径（DATABASE_TYPE=sqlite 时使用）
SQLITE_DB_PATH=data/bot.db

# PostgreSQL 连接 URL（DATABASE_TYPE=postgresql 时使用）
# DATABASE_URL=postgresql://user:password@host:5432/database_name

# MySQL 配置（DATABASE_TYPE=mysql 时使用）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=yhq_db

# ----------------------------------------
# 频道配置（可选）
# ----------------------------------------

# 强制订阅频道 ID，逗号分隔（用户启动时验证）
# REQUIRED_CHANNELS=-1001234567890,-1009876543210

# 报告推送频道 ID，逗号分隔（审核通过后推送）
# REPORT_CHANNELS=-1001234567890

# ----------------------------------------
# 日志配置
# ----------------------------------------

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ----------------------------------------
# 应用配置
# ----------------------------------------

# 应用环境：production / development
ENVIRONMENT=production

# 评价理由最小字数
MIN_REASON_LENGTH=12

# 预约截图最小数量
MIN_SCREENSHOTS=1

# 预约截图最大数量
MAX_SCREENSHOTS=3

# 排行榜显示数量
RANKING_LIMIT=10

# 搜索结果最大显示数量
SEARCH_RESULT_LIMIT=10
