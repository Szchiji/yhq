# ============================================================
# 报告管理系统 - 环境变量配置
# ============================================================

# ----------------------------------------
# Telegram Bot 配置（必填）
# ----------------------------------------

# Bot Token（从 @BotFather 获取）
BOT_TOKEN=123456789:ABCDEfghijklmnopqrstuvwxyz1234567890

# Bot 用户名（可选）
BOT_USERNAME=your_bot_username

# Bot 运行模式：polling / webhook / hybrid
BOT_MODE=polling

# Webhook 配置（BOT_MODE=webhook 时必填）
# WEBHOOK_URL=https://yourdomain.com
# WEBHOOK_HOST=0.0.0.0
# WEBHOOK_PORT=8000

# ----------------------------------------
# 管理员配置（必填）
# ----------------------------------------

# 管理员 Telegram ID 列表，用逗号分隔
# 获取方式：给机器人发 /start，查看日志
ADMIN_IDS=123456789,987654321

# ----------------------------------------
# 数据库配置
# ----------------------------------------

# 数据库类型：sqlite / postgresql
DATABASE_TYPE=postgresql

# PostgreSQL 连接 URL（推荐用于生产/Docker）
DATABASE_URL=postgresql://yhq_user:changeme@postgres:5432/yhq_db

# Docker PostgreSQL 认证（与 docker-compose.yml 匹配）
DB_USER=yhq_user
DB_PASSWORD=changeme
DB_NAME=yhq_db

# SQLite 路径（DATABASE_TYPE=sqlite 时使用，仅用于本地开发）
# SQLITE_DB_PATH=data/bot.db

# ----------------------------------------
# 安全配置（必填）
# ----------------------------------------

# JWT/API 密钥（生产环境必须设置为强随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-random-32-char-string

# API 访问密钥（用于 /api/v1/auth/token 端点）
API_KEY=your_api_key_here

# JWT 过期时间（秒，默认 3600 = 1 小时）
# JWT_EXPIRES_IN=3600

# ----------------------------------------
# CORS 配置（miniapp 跨域）
# ----------------------------------------

# 允许的来源，逗号分隔（* 允许所有，生产环境请具体指定）
CORS_ORIGINS=*

# ----------------------------------------
# 频道配置（可选）
# ----------------------------------------

# 强制订阅频道 ID，逗号分隔（用户启动时验证）
# REQUIRED_CHANNELS=-1001234567890,-1009876543210

# 报告推送频道 ID，逗号分隔（审核通过后推送）
# REPORT_CHANNELS=-1001234567890

# ----------------------------------------
# Redis 缓存配置（可选）
# ----------------------------------------

# Redis 连接 URL（未设置则使用内存缓存）
REDIS_URL=redis://redis:6379/0

# ----------------------------------------
# FastAPI 配置
# ----------------------------------------

# API 监听地址
API_HOST=0.0.0.0

# API 监听端口
API_PORT=8000

# ----------------------------------------
# 日志配置
# ----------------------------------------

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ----------------------------------------
# 应用配置
# ----------------------------------------

# 应用环境：production / development
ENVIRONMENT=production

# 报告表单配置
MIN_SCREENSHOTS=1
MAX_SCREENSHOTS=3

# 搜索结果最大显示数量
SEARCH_RESULT_LIMIT=10

# 排行榜显示数量
RANKING_LIMIT=10
