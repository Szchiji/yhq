BOT_TOKEN=your_telegram_bot_token_here

# ── Admin IDs ──────────────────────────────────────────────────────────────────
# ADMIN_IDS: comma-separated list of admin Telegram user IDs (preferred)
# If not set, falls back to ADMIN_ID (single admin, legacy)
ADMIN_IDS=5528758975
# ADMIN_ID=your_admin_telegram_id  # kept for backward compatibility

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telegram_report_bot

# ── URLs ──────────────────────────────────────────────────────────────────────
# In production (e.g. Railway), set these to your actual public URL (no trailing slash).
# Telegram inline keyboard buttons require a publicly accessible HTTPS URL.
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Bot launch mode ───────────────────────────────────────────────────────────
# BOT_MODE: polling | webhook | auto (default: auto)
#   auto    → webhook when WEBHOOK_URL is set AND NODE_ENV=production, otherwise polling
#   webhook → always webhook (requires WEBHOOK_URL)
#   polling → always polling (ignores WEBHOOK_URL, recommended for local dev)
BOT_MODE=auto

# WEBHOOK_URL: public base URL (no trailing slash)
# Required when BOT_MODE=webhook or BOT_MODE=auto in production
# Example: https://your-app.up.railway.app
WEBHOOK_URL=

# WEBHOOK_PATH: path Telegram will POST updates to (default: /webhook)
# Full registered URL will be: WEBHOOK_URL + WEBHOOK_PATH
WEBHOOK_PATH=/webhook

# ── Subscription chats (强制订阅) ──────────────────────────────────────────────
# Comma-separated list of channel/group IDs users must join to use the bot.
# ⚠️  REPLACE with your real chat IDs before deploying!
# Format: -100XXXXXXXXXX (private channels), @channelname (public channels)
# Example: REQUIRED_CHATS=-100123456789012,-100987654321098
# Leave empty to disable the subscription guard.
REQUIRED_CHATS=

# ── Publish channels (推送频道) ────────────────────────────────────────────────
# Comma-separated list of channel IDs to push approved reports to (text only).
# ⚠️  REPLACE with your real channel IDs before deploying!
# The bot must be an admin in each channel with "Post Messages" permission.
# Example: PUBLISH_CHATS=-100111222333444
# Leave empty to disable auto-push.
PUBLISH_CHATS=

